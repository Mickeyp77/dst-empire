{
    "name": "mnmsllc/dst-empire",
    "description": "Portfolio analysis engine for entity formation, tax structuring, and continuous compliance.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tax",
        "entity-formation",
        "compliance",
        "dst",
        "dynasty-trust",
        "asset-protection",
        "php"
    ],
    "homepage": "https://dstempire.com",
    "authors": [
        {
            "name": "MNMS LLC",
            "email": "hello@dstempire.com",
            "homepage": "https://dstempire.com"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Mnmsos\\Empire\\": "src/Empire/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mnmsos\\Empire\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "find src -name '*.php' -exec php -l {} \\;"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
