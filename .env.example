# DST Empire Configuration

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=dstempire
DB_USER=root
DB_PASS=

# Optional: Local Ollama for narrative intake parsing
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_PRIMARY_MODEL=hermes3-mythos:70b
OLLAMA_FALLBACK_MODELS=hermes3:8b,qwen2.5:7b

# Optional: Plaid (free dev tier — sign up at dashboard.plaid.com/signup)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# App encryption key (32 random bytes hex — generate via: openssl rand -hex 32)
APP_ENCRYPTION_KEY=

# Pandoc binary path (optional — for .docx/.pdf document rendering)
PANDOC_PATH=/usr/local/bin/pandoc
